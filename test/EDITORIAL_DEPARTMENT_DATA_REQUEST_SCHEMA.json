      ]
    },
    "socialAmplification": {
      "enables": [
        "Identify viral content patterns",
        "Understand audience sharing behavior",
        "Optimize posting times and formats",
        "Track brand sentiment",
        "Measure social campaign success"
      ]
    },
    "audienceRetention": {
      "enables": [
        "Reduce reader churn",
        "Increase subscriber lifetime value",
