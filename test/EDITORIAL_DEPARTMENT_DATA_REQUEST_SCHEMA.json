  "calculatedMetrics": {
    "engagementScore": {
      "formula": "(completionRate * 0.3) + (scrollDepth * 0.2) + (socialShares * 0.2) + (comments * 0.15) + (sessionDuration * 0.15)",
      "range": "0-100"
    },
    "viralityScore": {
      "formula": "(sharesFirst24Hours / averageShares) * shareVelocity * reachFactor",
      "range": "0-100"
    },
    "retentionRate": {
      "formula": "(usersActiveThisMonth AND activeLastMonth) / usersActiveLastMonth * 100",
      "range": "0-100%"
    },
    "churnRate": {
      "formula": "100 - retentionRate",
      "range": "0-100%"
    },
    "dauMauRatio": {
      "formula": "dailyActiveUsers / monthlyActiveUsers",
      "range": "0-1",
      "interpretation": "Higher is better - indicates user stickiness"
    }
  },

