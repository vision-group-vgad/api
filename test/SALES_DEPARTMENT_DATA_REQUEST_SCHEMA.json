        },
        "reportingDate": {
          "type": "string",
          "format": "date",
          "description": "Date for this performance snapshot",
          "example": "2026-02-15",
          "required": true
        },
        "totalRevenue": {
          "type": "number",
          "description": "Total revenue from territory",
          "example": 125000000,
          "required": true
        },
        "grossProfit": {
          "type": "number",
          "description": "Gross profit from territory",
          "example": 75000000,
          "required": true
        },
        "netProfit": {
          "type": "number",
          "description": "Net profit from territory",
          "example": 50000000,
          "required": true
        },
        "profitMarginPercent": {
          "type": "number",
          "description": "Profit margin percentage",
          "example": 40.0,
          "required": true
        },
        "totalSales": {
          "type": "number",
          "description": "Total number of sales transactions",
          "example": 350,
          "required": true
        },
        "averageSaleValue": {
          "type": "number",
          "description": "Average value per sale",
          "example": 357142,
          "required": true
        },
        "prospectedClients": {
          "type": "number",
          "description": "Number of prospected/contacted clients",
          "example": 1200,
          "required": true
        },
        "salesConversionRatePercent": {
          "type": "number",
          "description": "Conversion rate from prospects to sales",
          "example": 29.17,
          "required": true
        },
        "customerAcquisitionCost": {
          "type": "number",
          "description": "Average cost to acquire a customer",
          "example": 125000,
          "required": false
        },
        "returnOnMarketingInvestment": {
          "type": "number",
          "description": "ROMI ratio",
          "example": 4.5,
          "required": false
        },
        "activeCustomers": {
          "type": "number",
          "description": "Number of active customers in territory",
          "example": 850,
          "required": true
        },
        "newCustomers": {
          "type": "number",
          "description": "New customers acquired in period",
          "example": 45,
          "required": true
        },
        "lostCustomers": {
          "type": "number",
          "description": "Customers lost/churned in period",
          "example": 12,
          "required": true
        },
        "salesTeamSize": {
          "type": "number",
          "description": "Number of sales reps in territory",
          "example": 8,
          "required": true
        },
        "topPerformer": {
          "type": "string",
          "description": "Name of top sales rep in territory",
          "example": "John Smith",
          "required": false
        }
      }
    },

    "5_LEAD_GENERATION_EFFICIENCY": {
      "description": "Lead generation, qualification, and conversion funnel metrics",
      "endpoints": ["/api/v1/sales/lead-efficiency"],
      "requiredFields": {
        "leadId": {
          "type": "string",
          "description": "Unique lead identifier",
          "example": "LEAD-2026-5432",
          "required": true
        },
        "campaignId": {
          "type": "string",
          "description": "Source campaign ID",
          "example": "CAMP-2026-Q1-001",
          "required": true
        },
        "campaignName": {
          "type": "string",
          "description": "Source campaign name",
          "example": "LinkedIn B2B Campaign",
          "required": true
        },
        "leadSource": {
          "type": "string",
          "enum": ["Google Ads", "LinkedIn", "Facebook", "Referral", "Email", "Website", "Event", "Cold Call", "Partner"],
          "description": "Lead source channel",
          "required": true
        },
        "leadCreatedDate": {
          "type": "string",
          "format": "date-time",
          "description": "When lead was created",
          "example": "2026-02-01T10:30:00Z",
          "required": true
        },
        "currentStage": {
          "type": "string",
          "enum": ["Lead", "MQL", "SQL", "Opportunity", "Customer", "Closed Lost"],
          "description": "Current stage in sales funnel",
          "required": true
        },
        "leadScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Lead quality score (0-100)",
          "example": 75,
          "required": false
        },
        "qualifiedDate": {
          "type": "string",
          "format": "date-time",
          "description": "When lead was qualified (MQL/SQL)",
          "example": "2026-02-05T14:20:00Z",
          "required": false
        },
        "convertedDate": {
          "type": "string",
          "format": "date-time",
          "description": "When lead converted to customer",
          "required": false
        },
        "daysToQualification": {
          "type": "number",
          "description": "Days from lead creation to qualification",
          "example": 4,
          "required": false
        },
        "daysToConversion": {
          "type": "number",
          "description": "Days from lead creation to conversion",
          "example": 21,
          "required": false
        },
        "campaignSpend": {
          "type": "number",
          "description": "Marketing spend attributed to this lead",
          "example": 45000,
          "required": false
        },
        "expectedValue": {
          "type": "number",
          "description": "Expected revenue from this lead",
          "example": 2500000,
          "required": false
        },
        "actualValue": {
          "type": "number",
          "description": "Actual revenue if converted",
          "required": false
        },
        "assignedSalesRep": {
          "type": "string",
          "description": "Sales rep handling this lead",
          "example": "Mary Johnson",
          "required": true
        },
        "industry": {
          "type": "string",
          "description": "Lead's industry",
          "example": "Banking & Finance",
          "required": false
        },
        "companySize": {
          "type": "string",
          "enum": ["1-10", "11-50", "51-200", "201-500", "501-1000", "1000+"],
          "description": "Company size bracket",
          "required": false
        }
      }
    },

