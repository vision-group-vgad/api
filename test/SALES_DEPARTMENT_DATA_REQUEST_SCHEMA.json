{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sales & Marketing Department Data Request Schema",
  "description": "Comprehensive data schema for Vision Group Sales & Marketing Department Analytics - This document defines all required data fields to achieve accurate sales statistics, revenue metrics, and marketing KPIs",
  "version": "1.0.0",
  "lastUpdated": "2026-02-16",
  
  "dataCategories": {
    
    "1_REVENUE_ATTRIBUTION": {
      "description": "Revenue tracking by segment, product line, and business unit",
      "endpoints": ["/api/v1/sales/revenue-attribution"],
      "requiredFields": {
        "revenueId": {
          "type": "string",
          "description": "Unique revenue transaction identifier",
          "example": "REV-2026-00542",
          "required": true
        },
        "transactionDate": {
          "type": "string",
          "format": "date",
          "description": "Date of revenue transaction",
          "example": "2026-02-15",
          "required": true
        },
        "businessSegment": {
          "type": "string",
          "enum": ["Print Newspaper", "TV Broadcast", "Digital Subscriptions", "Education Publishing", "Commercial Printing", "Radio Broadcasting", "Events & Conferences", "Advertising Services"],
          "description": "Business segment generating revenue",
          "required": true
        },
        "revenueAmount": {
          "type": "number",
          "description": "Revenue amount in base currency",
          "example": 2500000,
          "required": true
        },
        "currency": {
          "type": "string",
          "description": "Currency code",
          "example": "UGX",
          "required": true
        },
        "revenueType": {
          "type": "string",
          "enum": ["Subscription", "Advertisement", "One-time Sale", "Recurring", "Project-based", "Commission"],
          "description": "Type of revenue",
          "required": true
        },
        "customerId": {
          "type": "string",
          "description": "Customer/client identifier",
          "example": "CUST-1234",
          "required": true
        },
        "customerName": {
          "type": "string",
          "description": "Customer/client name",
          "example": "ABC Corporation Ltd",
          "required": true
        },
        "customerType": {
          "type": "string",
          "enum": ["Corporate", "SME", "Individual", "Government", "NGO"],
          "description": "Type of customer",
          "required": true
        },
        "salesChannel": {
          "type": "string",
          "enum": ["Direct Sales", "Online", "Partner/Reseller", "Retail", "Phone Sales"],
          "description": "Channel through which sale was made",
          "required": true
        },
        "salesRepId": {
          "type": "string",
          "description": "Sales representative identifier",
          "example": "SREP-045",
          "required": true
        },
        "salesRepName": {
          "type": "string",
          "description": "Sales representative name",
          "example": "Jane Doe",
          "required": true
        },
        "territory": {
          "type": "string",
          "description": "Sales territory/region",
          "example": "Central Region",
          "required": true
        },
        "costOfSale": {
          "type": "number",
          "description": "Direct costs associated with this sale",
          "example": 1000000,
          "required": false
        },
        "grossProfit": {
          "type": "number",
          "description": "Gross profit from this transaction",
          "example": 1500000,
          "required": false
        },
        "profitMarginPercent": {
          "type": "number",
          "description": "Profit margin percentage",
          "example": 60.0,
          "required": false
        }
      }
    },

    "2_CLIENT_LIFETIME_VALUE": {
      "description": "Customer lifetime value, retention, and relationship metrics",
      "endpoints": ["/api/v1/sales/client-lifetime-value"],
      "requiredFields": {
        "customerId": {
          "type": "string",
          "description": "Unique customer identifier",
          "example": "CUST-5678",
          "required": true
        },
        "customerName": {
          "type": "string",
          "description": "Customer name",
          "example": "XYZ Enterprise",
          "required": true
        },
        "firstPurchaseDate": {
          "type": "string",
          "format": "date",
          "description": "Date of first purchase",
          "example": "2023-03-15",
          "required": true
        },
        "lastPurchaseDate": {
          "type": "string",
          "format": "date",
          "description": "Date of most recent purchase",
          "example": "2026-02-10",
          "required": true
        },
        "totalRevenue": {
          "type": "number",
          "description": "Total revenue generated from this customer",
          "example": 45000000,
          "required": true
        },
        "totalTransactions": {
          "type": "number",
          "description": "Total number of transactions",
          "example": 36,
          "required": true
        },
        "averageTransactionValue": {
          "type": "number",
          "description": "Average value per transaction",
          "example": 1250000,
          "required": true
        },
        "customerLifetimeMonths": {
          "type": "number",
          "description": "Number of months as active customer",
          "example": 35,
          "required": true
        },
        "lifetimeValue": {
          "type": "number",
          "description": "Calculated customer lifetime value",
          "example": 45000000,
          "required": true
        },
        "predictedLifetimeValue": {
          "type": "number",
          "description": "Predicted future lifetime value",
          "example": 75000000,
          "required": false
        },
        "acquisitionCost": {
          "type": "number",
          "description": "Cost to acquire this customer",
          "example": 500000,
          "required": false
        },
        "customerStatus": {
          "type": "string",
          "enum": ["Active", "Inactive", "At Risk", "Churned", "VIP"],
          "description": "Current customer status",
          "required": true
        },
        "churnRisk": {
          "type": "string",
          "enum": ["Low", "Medium", "High"],
          "description": "Risk of customer churning",
          "required": false
        },
        "lastContactDate": {
          "type": "string",
          "format": "date",
          "description": "Date of last contact/engagement",
          "required": false
        },
        "customerSegment": {
          "type": "string",
          "enum": ["Premium", "Standard", "Basic", "Enterprise"],
          "description": "Customer segment classification",
          "required": true
        },
        "referralSource": {
          "type": "string",
          "description": "How customer was acquired",
          "example": "Website",
          "required": false
        }
      }
    },

    "3_CAMPAIGN_ROI": {
      "description": "Marketing campaign performance and return on investment",
      "endpoints": ["/api/v1/sales/campaign-roi"],
      "requiredFields": {
        "campaignId": {
          "type": "string",
          "description": "Unique campaign identifier",
          "example": "CAMP-2026-Q1-001",
          "required": true
        },
        "campaignName": {
          "type": "string",
          "description": "Campaign name",
          "example": "Summer Digital Promotion 2026",
          "required": true
        },
        "campaignType": {
          "type": "string",
          "enum": ["Digital Marketing", "Print Advertising", "TV Campaign", "Radio Campaign", "Event Sponsorship", "Social Media", "Email Marketing", "Outdoor/Billboard"],
          "description": "Type of marketing campaign",
          "required": true
        },
        "startDate": {
          "type": "string",
          "format": "date",
          "description": "Campaign start date",
          "example": "2026-01-15",
          "required": true
        },
        "endDate": {
          "type": "string",
          "format": "date",
          "description": "Campaign end date",
          "example": "2026-03-31",
          "required": true
        },
        "totalBudget": {
          "type": "number",
          "description": "Total campaign budget",
          "example": 15000000,
          "required": true
        },
        "actualSpend": {
          "type": "number",
          "description": "Actual amount spent",
          "example": 14200000,
          "required": true
        },
        "impressions": {
          "type": "number",
          "description": "Total impressions/views",
          "example": 500000,
          "required": true
        },
        "clicks": {
          "type": "number",
          "description": "Total clicks (for digital campaigns)",
          "example": 25000,
          "required": false
        },
        "clickThroughRatePercent": {
          "type": "number",
          "description": "Click-through rate percentage",
          "example": 5.0,
          "required": false
        },
        "leads": {
          "type": "number",
          "description": "Number of leads generated",
          "example": 450,
          "required": true
        },
        "conversions": {
          "type": "number",
          "description": "Number of conversions/sales",
          "example": 90,
          "required": true
        },
        "conversionRatePercent": {
          "type": "number",
          "description": "Conversion rate percentage",
          "example": 20.0,
          "required": true
        },
        "revenueGenerated": {
          "type": "number",
          "description": "Total revenue attributed to campaign",
          "example": 45000000,
          "required": true
        },
        "roi": {
          "type": "number",
          "description": "Return on investment (ratio)",
          "example": 3.17,
          "required": true
        },
        "roiPercent": {
          "type": "number",
          "description": "ROI as percentage",
          "example": 217.0,
          "required": true
        },
        "costPerLead": {
          "type": "number",
          "description": "Cost to acquire each lead",
          "example": 31555,
          "required": true
        },
        "costPerAcquisition": {
          "type": "number",
          "description": "Cost to acquire each customer",
          "example": 157777,
          "required": true
        },
        "targetAudience": {
          "type": "string",
          "description": "Target demographic/audience",
          "example": "Business professionals 25-45",
          "required": false
        },
        "channels": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Marketing channels used",
          "example": ["Facebook", "Google Ads", "LinkedIn"],
          "required": true
        }
      }
    },

    "4_TERRITORY_PERFORMANCE": {
      "description": "Sales performance by geographic territory and region",
      "endpoints": ["/api/v1/sales/territory-performance"],
      "requiredFields": {
